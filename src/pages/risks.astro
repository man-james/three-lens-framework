---
import BaseLayout from '../layouts/BaseLayout.astro';
import RiskTable from '../components/RiskTable.tsx';
---
<BaseLayout title="Risk Taxonomy" description="Browse all 87 AI agent risks across 11 categories and 3 axes. Filter by tier, axis, category. Click any risk to expand the full description and linked mitigations.">
  <section class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">Risk Taxonomy</h1>
      <p class="text-muted mt-2">87 risks across 11 categories, organized under three lenses. Filter, search, click to expand. <a href="/assess" class="text-action hover:underline">Switch to scoring mode →</a></p>
    </div>
    <RiskTable mode="browse" client:only="preact" />
  </section>
</BaseLayout>
