---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Downloads" description="Download the Three-Lens Framework assessment workbook, risk register, executive briefing, and all reference files.">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-8">Downloads</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <a href="/downloads/framework-v3-assessment-template.xlsx" class="card group hover:border-action/50 transition-all">
        <h3 class="text-white font-bold mb-1">Assessment Workbook</h3>
        <p class="text-muted text-xs mb-2">Excel (.xlsx) — 9 sheets: Tutorial, 3 Scoring tabs, Action Plan, Inventory, Risk Reference, Mitigation Reference, History tracker</p>
        <span class="text-action text-sm font-medium group-hover:underline">Download .xlsx</span>
      </a>
      <a href="/downloads/framework-v3-risk-register.csv" class="card group hover:border-action/50 transition-all">
        <h3 class="text-white font-bold mb-1">Risk Register</h3>
        <p class="text-muted text-xs mb-2">CSV — All 87 risks with IDs, tiers, categories, descriptions, and primary/secondary mitigations</p>
        <span class="text-action text-sm font-medium group-hover:underline">Download .csv</span>
      </a>
      <a href="/downloads/framework-v3-executive-briefing.pptx" class="card group hover:border-action/50 transition-all">
        <h3 class="text-white font-bold mb-1">Executive Briefing</h3>
        <p class="text-muted text-xs mb-2">PowerPoint (.pptx) — 5 slides: Incidents, Three Lenses, 15 Critical Risks, Cost of Inaction, First Five</p>
        <span class="text-action text-sm font-medium group-hover:underline">Download .pptx</span>
      </a>
      <a href="/downloads/framework-v3-practitioner-card.pptx" class="card group hover:border-action/50 transition-all">
        <h3 class="text-white font-bold mb-1">Practitioner Card</h3>
        <p class="text-muted text-xs mb-2">PowerPoint (.pptx) — Single printable slide with First Five, Phase 2, tier triage, scoring scale</p>
        <span class="text-action text-sm font-medium group-hover:underline">Download .pptx</span>
      </a>
    </div>
    <p class="text-muted text-xs mt-8 text-center">All files are also available in the <a href="https://github.com/james-man/three-lens-framework" class="text-operational hover:underline">GitHub repository</a>.</p>
  </section>
</BaseLayout>
